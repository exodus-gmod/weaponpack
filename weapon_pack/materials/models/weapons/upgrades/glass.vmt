"VertexlitGeneric"
{
	$basetexture 			    "models\weapons\upgrades\rmr_d"
	$bumpmap 				    "models\weapons\upgrades\rmr_n"
	"$color" 		            "[.1 .1 .5]"
	"$translucent" 	            "1"
	"$model" 		            "1"
	
	"normalmapalphaenvmapmask"	"1"
	
	"$phong"		            "1"
	"$phongboost"               "10"
	"$phongexponent"         	"80"
	"$phongfresnelranges"		"[2 4 8]"
	"$phongtint"	            "[0.65 0.85 1]"
	
	"$envmap" 	                "env_cubemap"
	"$envmaptint" 	            "[0.1 1 0.5]"
	"$envmapcontrast" 	        "1"
	//"$envmapsaturation"       "1"

	"Proxies"
	{
		"IronsightVectorResult"
		{
			"resultVar"		"$envmaptint"
			"ResultDefault"	"0.1 1.0 0.5"
			"ResultZoomed"	"0.1 0.5 0.1"
		}
	}
}