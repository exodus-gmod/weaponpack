"UnlitGeneric"

{
	"$basetexture"	"models/weapons/tfa_eft/upgrades/scopes/MRS/mrs_reticle_4"
	"$model"		"1"
	"$additive"	"1"
	"$vertexcolor"	"1"
	"$vertexalpha"	"1"
	"$translucent" 	"1"

	"$detail"		"models/weapons/tfa_eft/upgrades/scopes/noise1"
	"$detailblendmode" "2"
	"$detailframe"	"0"

	$color2 "[1 0 0]"

	Proxies
	{
		TFAReticuleColor
		{
			resultVar $color2
		}

		TextureScroll
		{
			textureScrollVar	$detailtexturetransform
