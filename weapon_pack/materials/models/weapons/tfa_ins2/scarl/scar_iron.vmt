Vertexlitgeneric
{

	// MAIN SETTINGS
	"$basetexture" "models\weapons\tfa_ins2\scarl\scar_iron_d"
	"$bumpmap"     "models\weapons\tfa_ins2\scarl\scar_iron_n"
	"$nocull" "1"
	// PHONG SHADING
	$phong                      1
	$phongboost                 0.8
	$phongfresnelranges         "[.5 1 3]"
	$phongtint                  "[.8 .8 1.2]"
	$normalmapalphaphongmask    1

	// ENVIRONMENT REFLECTION
	$envmap                     env_cubemap
	$envmaptint                 "[.045 .045 .055]"
	$normalmapalphaenvmapmask   1



}